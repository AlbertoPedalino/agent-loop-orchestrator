# Example environment file.
# Do not put real secrets here; copy to .env (gitignored) and fill in.
#
# These keys are used only when a run selects `backend: api` (API-key billing).
# With the default `backend: cli` (subscription auth) they are ignored and
# stripped from the CLI subprocess environment, so a filled .env cannot
# silently switch a subscription run to API billing.

# Claude Code with backend: api
ANTHROPIC_API_KEY=

# Codex with backend: api (CODEX_API_KEY is also set from this value)
OPENAI_API_KEY=

# Optional: override Claude CLI executable name/path.
CLAUDE_CLI=claude
